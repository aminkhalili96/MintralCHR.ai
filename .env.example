# Supabase
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=medchr-uploads

# Mistral API (OpenAI-compatible interface)
MISTRAL_API_KEY=
OPENAI_BASE_URL=https://api.mistral.ai/v1
OPENAI_MODEL=mistral-large-latest
OPENAI_EMBEDDING_MODEL=mistral-embed
OPENAI_TIMEOUT_SECONDS=30

# App
APP_ENV=dev
LOG_LEVEL=info
APP_BASE_URL=http://127.0.0.1:8000
API_DOCS_ENABLED=true
APP_SECRET_KEY=change-me
# Optional env-based key(s). Format: tenant_uuid:key,tenant_uuid:key2
# Preferred in production: leave empty and provision DB-backed keys via:
#   python -m backend.scripts.create_api_key --tenant-id <uuid> --name <name>
API_KEYS=

# Security / HIPAA
HIPAA_MODE=false
PHI_PROCESSORS=
PHI_REDACTION_ENABLED=false
MFA_SECRET_KEY=
CSRF_ENABLED=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ORIGINS=
REFERRER_POLICY=no-referrer
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
RATE_LIMIT_DEFAULT=60/minute

# Uploads
MAX_UPLOAD_MB=25
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/tiff,text/plain
MALWARE_SCAN_ENABLED=false
MALWARE_SCAN_TIMEOUT_SECONDS=30

# DB Pool
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_STATEMENT_TIMEOUT_MS=15000

# Embedding chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Background jobs
JOB_QUEUE_ENABLED=false
JOB_POLL_INTERVAL_SECONDS=5
JOB_MAX_ATTEMPTS=3

# Data retention
AUDIT_RETENTION_DAYS=365
JOB_RETENTION_DAYS=30

# Session
SESSION_COOKIE_NAME=medchr_session
SESSION_MAX_AGE_MINUTES=720
STEP_UP_WINDOW_MINUTES=15

# SSO (optional)
OIDC_ENABLED=false
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
AZURE_AD_ENABLED=false
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
GOOGLE_WORKSPACE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_CERT=
SSO_ALLOWED_DOMAINS=
SSO_ALLOWED_PROVIDERS=
SSO_REQUIRE_VERIFIED_EMAIL=true

# Queue backend
REDIS_URL=
REDIS_QUEUE_NAME=medchr:jobs

# Bootstrap (local/dev convenience)
# Creates a tenant + first admin user for /ui login:
#   python -m backend.scripts.bootstrap_admin
BOOTSTRAP_TENANT_NAME=System Tenant
BOOTSTRAP_TENANT_ID=00000000-0000-0000-0000-000000000000
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# Retention export
RETENTION_EXPORT_DIR=data/retention_exports
RETENTION_IMMUTABLE_DIR=data/retention_immutable
